{
  "name": "mcsmcpapps-mcp-server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "MCP server that exposes a single tool, openCopilotStudioChat, which renders the MCSMCPapps WebChat as a UI widget inside Microsoft 365 Copilot.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^4.21.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "~5.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
