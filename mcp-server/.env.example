# Copy to .env or set as environment variables on your host (Function App, App Service).
# These bake into the served widget HTML at runtime.

# The hostname of the Static Web App where the WebChat is hosted.
SWA_ORIGIN=https://icy-field-07d5bef1e.7.azurestaticapps.net

# Display name shown in the widget header before the SWA loads.
AGENT_NAME=Eurozone Analyst

# Description used as the tool description Copilot shows the user.
AGENT_DESCRIPTION=Open the embedded Eurozone Analyst chat surface.

# Local dev port.
PORT=3000
