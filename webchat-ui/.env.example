# Local-only environment overrides — copy to .env and fill in real values.
# .env is gitignored. Production values come from SWA Configuration (set per environment).

# --- Copilot Studio agent identity (Phase 2) ---
# Schema name from Copilot Studio agent → Channels → Web app embed code, or
# Settings → Advanced → Schema name. Looks like cr1a2_myAgent or ksteam_ak001.
VITE_CS_SCHEMA_NAME=ksteam_ak001

# Power Platform Environment GUID (from the maker portal URL .../environments/<this>/...).
VITE_CS_ENVIRONMENT_ID=61453fde-f312-e19f-b879-a2dfa518e914

# Optional: override the SDK's computed direct-connect URL. Leave blank for default.
VITE_CS_DIRECT_CONNECT_URL=

# --- Entra app registration (Phase 7, lives in the CS tenant) ---
VITE_AAD_CLIENT_ID=701e58d1-3d3b-42e8-b2a4-864ba5fe2c61
VITE_AAD_AUTHORITY=https://login.microsoftonline.com/301759bc-5be1-40f1-8a44-822e286f5a9d

# Power Platform API scope.
# Use the named scope for cleaner consent prompts; .default also works.
VITE_AAD_SCOPE=https://api.powerplatform.com/CopilotStudio.Copilots.Invoke

# --- Branding (all optional; sensible defaults if omitted) ---
# Anything you set here is baked into the bundle at build time. SWA
# Configuration overrides take effect on the next CI run.
#
# To change branding at runtime per-user/per-tenant, have a CS topic emit
# an outbound event named 'rebrand' with a partial Branding payload.

VITE_BRAND_AGENT_NAME=Eurozone Analyst
VITE_BRAND_AGENT_SUBTITLE=AI economic briefings for the Euro area
VITE_BRAND_COMPANY_NAME=Contoso Electronics
# Logo: emoji, https URL, or data: URL. Empty string omits.
VITE_BRAND_LOGO=€
VITE_BRAND_ACCENT_COLOR=#003399
VITE_BRAND_ACCENT_FOREGROUND=#ffd200
# Font: any valid CSS font-family stack.
VITE_BRAND_FONT_FAMILY="Segoe UI", system-ui, -apple-system, Roboto, sans-serif
VITE_BRAND_PAGE_TITLE=Eurozone Analyst
