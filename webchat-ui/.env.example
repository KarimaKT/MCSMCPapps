# Local-only environment overrides — copy to .env and fill in real values.
# .env is gitignored. Production values come from SWA Configuration (set per environment).

# --- Copilot Studio agent identity (Phase 2) ---
# Schema name from Copilot Studio agent → Settings → Advanced → Schema name.
# Looks like cr1a2_myAgent.
VITE_CS_SCHEMA_NAME=

# Bot GUID, parsed from the maker portal URL .../bots/<this>/...
VITE_CS_BOT_ID=9d6e6825-7945-f111-bec6-7ced8dcd844a

# Power Platform Environment GUID (.../environments/<this>/...).
VITE_CS_ENVIRONMENT_ID=61453fde-f312-e19f-b879-a2dfa518e914

# Token endpoint exposed by the CS agent → Settings → Channels → Direct Line / Mobile.
# Looks like https://<region>.api.powerplatform.com/copilotstudio/dataverse-backed/...
VITE_CS_TOKEN_ENDPOINT=

# --- Entra app registration (Phase 7, lives in the CDX tenant) ---
VITE_AAD_CLIENT_ID=
VITE_AAD_AUTHORITY=https://login.microsoftonline.com/301759bc-5be1-40f1-8a44-822e286f5a9d
VITE_AAD_SCOPE=
