{
  "name": "mcsmcpapps-webchat-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Embedded Bot Framework Web Chat surface for the Copilot Studio agent, hosted on Azure Static Web Apps and loaded by the MCP App tool inside Microsoft 365 Copilot.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json && vite build",
    "build:widget": "tsc -p tsconfig.json && vite build --config vite.widget.config.ts",
    "build:all": "npm run build && npm run build:widget",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@azure/msal-browser": "^3.27.0",
    "@microsoft/agents-copilotstudio-client": "^1.5.1",
    "@microsoft/teams-js": "^2.30.0",
    "adaptivecards": "^3.0.6",
    "botframework-webchat": "^4.18.1-main.20251219.4ef3594",
    "botframework-webchat-fluent-theme": "^4.18.1-main.20251219.4ef3594",
    "dompurify": "^3.4.2",
    "marked": "^18.0.3",
    "react": "^16.8.6",
    "react-dom": "^16.8.6"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "@types/react": "^16.14.65",
    "@types/react-dom": "^16.9.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "~5.6.0",
    "vite": "^5.4.0",
    "vite-plugin-singlefile": "^2.0.3"
  },
  "engines": {
    "node": ">=20"
  }
}
