{
  "$schema": "https://developer.microsoft.com/json-schemas/teams/v1.22/MicrosoftTeams.schema.json",
  "manifestVersion": "1.22",
  "version": "1.1.1",
  "id": "${{TEAMS_APP_ID}}",
  "developer": {
    "name": "MCSMCPapps Maker",
    "websiteUrl": "https://github.com/KarimaKT/MCSMCPapps",
    "privacyUrl": "https://github.com/KarimaKT/MCSMCPapps/blob/main/SECURITY.md",
    "termsOfUseUrl": "https://github.com/KarimaKT/MCSMCPapps/blob/main/LICENSE"
  },
  "icons": {
    "color": "color.png",
    "outline": "outline.png"
