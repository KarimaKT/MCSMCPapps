  "name": {
    "short": "Eurozone Analyst",
    "full": "Eurozone Analyst (MCSMCPapps)"
  },
  "description": {
    "short": "Embedded Copilot Studio agent.",
    "full": "Embeds the Eurozone Analyst Copilot Studio agent inside Microsoft 365 Copilot using the MCP-server-backed UI widget pattern."
